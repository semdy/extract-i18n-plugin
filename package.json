{
  "name": "extract-i18n-plugin",
  "version": "1.1.45",
  "type": "module",
  "module": "lib/index.js",
  "main": "cjs/index.cjs",
  "types": "types/index.d.ts",
  "bin": {
    "extract-i18n": "lib/cli.js"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "require": "./cjs/index.cjs",
      "import": "./lib/index.js"
    },
    "./options": {
      "types": "./types/options.d.ts",
      "require": "./cjs/options.cjs",
      "import": "./lib/options.js"
    },
    "./translators": {
      "types": "./types/translators/index.d.ts",
      "require": "./cjs/translators/index.cjs",
      "import": "./lib/translators/index.js"
    },
    "./babel-plugin-i18n": {
      "types": "./types/babel-plugin-i18n.d.ts",
      "require": "./cjs/babel-plugin-i18n.cjs",
      "import": "./lib/babel-plugin-i18n.js"
    },
    "./babel-plugin-i18n-import": {
      "types": "./types/babel-plugin-i18n-import.d.ts",
      "require": "./cjs/babel-plugin-i18n-import.cjs",
      "import": "./lib/babel-plugin-i18n-import.js"
    },
    "./webpack-i18n-loader": {
      "types": "./types/webpack-i18n-loader.d.ts",
      "require": "./cjs/webpack-i18n-loader.cjs",
      "import": "./lib/webpack-i18n-loader.js"
    },
    "./webpack-i18n-import-loader": {
      "types": "./types/webpack-i18n-import-loader.d.ts",
      "require": "./cjs/webpack-i18n-import-loader.cjs",
      "import": "./lib/webpack-i18n-import-loader.js"
    },
    "./client": {
      "types": "./types/extract-i18n.config.d.ts"
    }
  },
  "keywords": [
    "i18n-extract-plugin",
    "i18n",
    "i18n-extract",
    "vue-i18n",
    "react-intl",
    "react-i18next",
    "react-i18n"
  ],
  "files": [
    "cjs",
    "lib",
    "types",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "author": "501859275@qq.com",
  "homepage": "https://github.com/semdy/extract-i18n-plugin",
  "license": "MIT",
  "description": "A set of plugins for extracting i18n messages from source code and translate/compile them. Both supports React/Preact/Vue/Svelte/Solid/Qwik/Lit/Angular/Ember/Marko based apps",
  "scripts": {
    "build": "node build.js"
  },
  "peerDependencies": {
    "@angular/compiler": "^22.0.4",
    "@glimmer/syntax": "*",
    "prettier-plugin-marko": "^4.0.9",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^4 || ^5",
    "vite": ">5.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/compiler": {
      "optional": true
    },
    "@glimmer/syntax": {
      "optional": true
    },
    "prettier-plugin-svelte": {
      "optional": true
    },
    "prettier-plugin-marko": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/core": "^8.0.1",
    "@babel/generator": "^8.0.0",
    "@babel/helper-plugin-utils": "^8.0.1",
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "@rollup/pluginutils": "^5.4.0",
    "@types/tunnel": "^0.0.7",
    "@vitalets/google-translate-api": "^9.2.1",
    "@vue/compiler-dom": "^3.5.39",
    "@vue/compiler-sfc": "^3.5.39",
    "axios": "^1.18.1",
    "c12": "^4.0.0-beta.5",
    "crypto-js": "^4.2.0",
    "esbuild": "^0.28.1",
    "esbuild-register": "^3.6.0",
    "fs-extra": "^11.3.5",
    "htmljs-parser": "^5.12.0",
    "magic-string": "^0.30.21",
    "prettier": "^3.9.1",
    "tinyglobby": "^0.2.17",
    "tunnel": "0.0.6"
  },
  "devDependencies": {
    "@angular/compiler": "22.0.4",
    "@glimmer/syntax": "0.95.0",
    "prettier-plugin-marko": "4.0.9",
    "prettier-plugin-svelte": "4.1.1",
    "svelte": "5.56.4"
  }
}
