{
  "name": "extract-i18n-plugin",
  "version": "1.1.44",
  "type": "module",
  "module": "lib/index.js",
  "main": "cjs/index.cjs",
  "types": "types/index.d.ts",
  "bin": {
    "extract-i18n": "lib/cli.js"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "require": "./cjs/index.cjs",
      "import": "./lib/index.js"
    },
    "./options": {
      "types": "./types/options.d.ts",
      "require": "./cjs/options.cjs",
      "import": "./lib/options.js"
    },
    "./translators": {
      "types": "./types/translators/index.d.ts",
      "require": "./cjs/translators/index.cjs",
      "import": "./lib/translators/index.js"
    },
    "./babel-plugin-i18n": {
      "types": "./types/babel-plugin-i18n.d.ts",
      "require": "./cjs/babel-plugin-i18n.cjs",
      "import": "./lib/babel-plugin-i18n.js"
    },
    "./babel-plugin-i18n-import": {
      "types": "./types/babel-plugin-i18n-import.d.ts",
      "require": "./cjs/babel-plugin-i18n-import.cjs",
      "import": "./lib/babel-plugin-i18n-import.js"
    },
    "./webpack-i18n-loader": {
      "types": "./types/webpack-i18n-loader.d.ts",
      "require": "./cjs/webpack-i18n-loader.cjs",
      "import": "./lib/webpack-i18n-loader.js"
    },
    "./webpack-i18n-import-loader": {
      "types": "./types/webpack-i18n-import-loader.d.ts",
      "require": "./cjs/webpack-i18n-import-loader.cjs",
      "import": "./lib/webpack-i18n-import-loader.js"
    },
    "./client": {
      "types": "./types/extract-i18n.config.d.ts"
    }
  },
  "keywords": [
    "i18n-extract-plugin",
    "i18n",
    "i18n-extract",
    "vue-i18n",
    "react-intl",
    "react-i18next",
    "react-i18n"
  ],
  "files": [
    "cjs",
    "lib",
    "types",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "author": "501859275@qq.com",
  "homepage": "https://github.com/semdy/extract-i18n-plugin",
  "license": "MIT",
  "description": "A set of plugins for extracting i18n messages from source code and translate/compile them. Both supports React/Preact/Vue/Svelte/Solid/Qwik/Lit/Angular/Ember/Marko based apps",
  "scripts": {
    "build": "node build.js"
  },
  "peerDependencies": {
    "@angular/compiler": "^21",
    "@glimmer/syntax": "*",
    "prettier-plugin-marko": "^4",
    "prettier-plugin-svelte": "^3",
    "svelte": "^4 || ^5",
    "vite": ">5.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/compiler": {
      "optional": true
    },
    "@glimmer/syntax": {
      "optional": true
    },
    "prettier-plugin-svelte": {
      "optional": true
    },
    "prettier-plugin-marko": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/core": "^7.27.3",
    "@babel/generator": "^7.27.3",
    "@babel/helper-plugin-utils": "^7.27.1",
    "@babel/parser": "^7.27.3",
    "@babel/traverse": "^7.27.3",
    "@babel/types": "^7.27.3",
    "@rollup/pluginutils": "^5.1.4",
    "@types/tunnel": "^0.0.7",
    "@vitalets/google-translate-api": "^9.2.0",
    "@vue/compiler-dom": "^3.5.16",
    "@vue/compiler-sfc": "^3.5.16",
    "axios": "^1.6.8",
    "c12": "^4.0.0-beta.4",
    "crypto-js": "^4.2.0",
    "esbuild": "^0.27.2",
    "esbuild-register": "^3.6.0",
    "fs-extra": "^11.3.0",
    "htmljs-parser": "^5.10.2",
    "magic-string": "^0.30.17",
    "prettier": "^3.5.3",
    "tinyglobby": "^0.2.15",
    "tunnel": "0.0.6"
  },
  "devDependencies": {
    "@angular/compiler": "^21.2.5",
    "@glimmer/syntax": "^0.95.0",
    "prettier-plugin-marko": "^4.0.8",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.53.7"
  }
}
